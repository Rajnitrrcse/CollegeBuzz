<% layout("../views/layouts/boilerplate.ejs") %>
<body>
    <div class="row">
    <div class="col-8 offset-2">
      <br>
    <h2>Signup and become Member of this Family</h2>
    <br>
      
    <form method="post" action="/index/user/signup" class="needs-validation" novalidate >
     <div class="mb-3">
        <label for="username" class="form-label">Username:</label>
      <input type="text" name="username" id="username"  required placeholder="@CollezeBuzz" class="form-control">
      <div class="valid-feedback">Username looks good</div>
      <div class="invalid-feedback">Username should be valid</div>
      </div>  
        
      
       <div class="mb-3">
      <label for="name" class="form-label">Your good name:</label>
      <input type="text"class="form-control"   name="name" id="name" placeholder="Raj Gupta" required>
      </div>


 <div class="row">
         <div class="mb-3 col-md-4">
        <label for="email" class="form-label">email:</label>
      <input type="email" name="email" id="email"  required  class="form-control">
      <div class="valid-feedback">email looks good</div>
      <div class="invalid-feedback">email should be valid</div>
      </div> 
        <div class="mb-3  col-md-8">
     <label for="mobile" class="form-label">Enter your Phone Number(+91):</label>
     <input type="number" name="mobile" id="mobile"  required  min="1000000000" max="9999999999"  class="form-control">
         <div class="valid-feedback">Looks good</div>
      <div class="invalid-feedback">Mobile number should be valid</div>
    </div>
       </div>

        <div class="mb-3">
      <label for="roll" class="form-label">Roll number:</label>
      <input type="number"class="form-control" name="roll"    id="roll"  required>
      </div>

    <div class="mb-3">
      <label for="password" class="form-label">Strong paswword:</label>
      <input type="password"class="form-control" name="password"  placeholder="Enter a Strong Password"  id="password"  required>
      </div>
      <button id="Mylovelybtn" class="btn btn-dark first-type">Signup</button>
       <br> <br>
    </form>
  </div>
  </div>
</body>
 