<% layout("../views/layouts/boilerplate.ejs") %>
<body>
    <div class="row">
    <div class="col-8 offset-2">
      <br>
    <h2>Login to collegeBuzz</h2>
    <br>
      
    <form method="post" action="/index/user/login/admin" class="needs-validation" novalidate >
     <div class="mb-3">
        <label for="username" class="form-label">Username:</label>
      <input type="text" name="username" id="username"  required placeholder="Enter your username" class="form-control">
      <div class="valid-feedback">Username looks good</div>
      <div class="invalid-feedback">Username should be valid</div>
      </div>  
        
    <div class="mb-3">
      <label for="password" class="form-label"> paswword:</label>
      <input type="text"class="form-control" name="password"  placeholder="Enter Your Password"  id="password"  required>
      </div>

      <div class="mb-3">
      <label for="id_admin" class="form-label">Your id number:</label>
      <input type="password"class="form-control" name="id_admin"  placeholder="Enter Your id number"  id="id_admin"  required>
      </div>


      <button id="Mylovelybtn" class="btn btn-dark first-type">Login</button>
       <br> <br>
    </form>
  </div>
  </div>
</body>
 