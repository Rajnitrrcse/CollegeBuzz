<% layout("../views/layouts/boilerplate.ejs") %>

    <div class="row">
    <div class="col-8 offset-2">
      <br>
    <h2>Claim</h2>
    <br>
      
    <form method="post" action="/index/lostfound/<%= lostfoundid %>/claim" class ="needs-validation" novalidate >
     
     
        <div class="mb-3">
        <label for="name" class="form-label">Full Name:</label>
      <input type="text" name="name" id="name"  required placeholder="Enter your Full name" class="form-control">
      <div class="invalid-feedback">Full name should be valid</div>
      </div> 


        <div class="mb-3">
        <label for="email" class="form-label">College-email:</label>
      <input type="email" name="email" id="email"  required placeholder="Enter Your college email" class="form-control">
      <div class="valid-feedback">email looks good</div>
      <div class="invalid-feedback">email should be valid</div>
      </div> 



 <div class="row">
         <div class="mb-3 col-md-4">
          <label for="branch" class="form-label">Branch:</label>
      <input  name="branch"  required  id="branch" class="form-control" placeholder="Enter Branch">
         <div class="valid-feedback">Looks good</div>
      <div class="invalid-feedback">branch should be valid</div>    
    </div>

        <div class="mb-3  col-md-8">
     <label for="roll" class="form-label">Roll number:</label>
     <input type="number" name="roll" id="roll"  required    class="form-control" placeholder="Enter your roll number">
         <div class="valid-feedback">Looks good</div>
      <div class="invalid-feedback">event Date  should be valid</div>
    </div>
       </div>

       <div class="mb-3">
      <label for="mobile" class="form-label">mobile-number:</label>
      <input type="text"class="form-control"   name="mobile" id="mobile" placeholder="Enter your mobile number" required>
      </div>

       <div class="mb-3">
      <label for="description" class="form-label">description:</label>
      <input type="text"class="form-control"   name="description" id="description" placeholder="Do you have any proof ?(optional)" required>
      </div>

    <div class="mb-3">
      <label for="year" class="form-label">Your Current Year of study:</label>
      <input type="number"class="form-control" name="year"    id="year"  required>
      </div>


      <button id="Mylovelybtn" class="btn btn-dark first-type ">claim</button>
       <br> <br>
    </form>
  </div>
  </div>

 